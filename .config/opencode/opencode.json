{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "*": "ask",
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "bash": {
      "*": "ask",
      "grep *": "allow",
      "head": "allow",
      "tail": "allow"
    }
  },
  "agent": {
    "build": {
      "mode": "primary",
      "model": "opencode/deepseek-v4-flash-free",
      "variant": "medium"
    },
    "plan": {
      "mode": "primary",
      "model": "opencode/deepseek-v4-flash-free",
      "variant": "high"
    }
  },
  "plugin": ["@mohak34/opencode-notifier@latest"]
}
