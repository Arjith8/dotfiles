{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "*": "ask",
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "bash": {
      "*": "ask"
    }
  },
  "agent": {
    "build": {
      "mode": "primary",
      "model": "opencode-go/kimi-k2.6"
    },
    "plan": {
      "mode": "primary",
      "model": "opencode-go/deepseek-v4-pro",
      "reasoningEffort": "high"
    }
  },
  "plugin": ["@mohak34/opencode-notifier@latest"]
}
